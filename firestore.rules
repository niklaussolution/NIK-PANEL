rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Plans — public read, admin write
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Razorpay plan cache — admin only
    match /razorpay_plans/{planId} {
      allow read, write: if isAdmin();
    }

    // Order ID counters — signed-in users can increment
    match /_counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    // Subscriptions (Razorpay)
    match /subscriptions/{subId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Orders (both Razorpay and UPI)
    match /orders/{orderId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      // User creates their own order
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      // User can update paymentProof only (not status fields); admin can update anything
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.paymentStatus == resource.data.paymentStatus &&
        request.resource.data.orderStatus == resource.data.orderStatus &&
        request.resource.data.userId == resource.data.userId
      );
      allow delete: if isAdmin();
    }

    // VPS
    match /vps/{vpsId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Payments (Razorpay)
    match /payments/{paymentId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Transactions (UPI approvals)
    match /transactions/{transactionId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      // User can mark their own notification as read
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

    // Tickets
    match /tickets/{ticketId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
